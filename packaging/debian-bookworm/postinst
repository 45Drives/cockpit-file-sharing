#!/bin/sh
set -e

VENV_DIR="/usr/share/cockpit/file-sharing/venv"

if [ "$1" = "configure" ] || [ "$1" = "triggered" ]; then
  if command -v python3 >/dev/null 2>&1; then
    python3 -m venv "$VENV_DIR" 2>/dev/null || :
    if [ -x "$VENV_DIR/bin/pip" ]; then
      "$VENV_DIR/bin/pip" install awscurl || :
    fi
    if [ -x "$VENV_DIR/bin/awscurl" ]; then
      ln -sf "$VENV_DIR/bin/awscurl" /usr/local/bin/awscurl
    fi
  fi
fi

exit 0
